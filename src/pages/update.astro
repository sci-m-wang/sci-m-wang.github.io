---
import BaseLayout from "../layouts/BaseLayout.astro";

const tokenUrl = "https://github.com/settings/personal-access-tokens/new?name=Academic%20Homepage%20Editor&description=Encrypted%20credential%20for%20sci-m-wang.github.io&target_name=sci-m-wang&expires_in=365&contents=write";
---

<BaseLayout
  title="Edit homepage · Ming Wang"
  description="Private, password-unlocked content editor for Ming Wang's academic homepage."
  noindex={true}
  secureEditor={true}
>
  <main class="update-page portal-page" id="main">
    <nav class="update-page__nav" aria-label="Homepage editor navigation">
      <a href="/">← Ming Wang / 王明</a>
      <span>OWNER EDITOR · ENCRYPTED VAULT</span>
    </nav>

    <div class="portal-alert" id="portal-alert" role="status" aria-live="polite" hidden></div>

    <section class="portal-auth portal-auth--unlock" id="auth-panel" aria-labelledby="auth-title">
      <div class="portal-auth__intro">
        <div class="portal-auth__eyebrow">
          <p class="section-heading__index" id="auth-kicker">01 · Unlock / 解锁</p>
          <span class="portal-vault-status" id="vault-status">正在检查保险箱…</span>
        </div>
        <h2 id="auth-title">Welcome back.</h2>
        <p id="auth-copy-en">Enter your homepage password. Decryption happens locally in this browser.</p>
        <p id="auth-copy-zh">输入主页管理密码即可进入。解密只发生在当前浏览器中。</p>
      </div>

      <form class="portal-auth__form portal-unlock-form" id="login-form" autocomplete="off" hidden>
        <label class="portal-field portal-field--wide" for="vault-password">
          <span>管理密码 <small>Homepage password</small></span>
          <span class="portal-password-control">
            <input
              id="vault-password"
              name="vault-password"
              type="password"
              placeholder="输入固定密码"
              autocomplete="current-password"
              autocapitalize="none"
              spellcheck="false"
              required
            />
            <button type="button" class="portal-password-toggle" data-password-toggle="vault-password" aria-label="显示密码">显示</button>
          </span>
          <small class="portal-caps-hint" data-caps-hint hidden>Caps Lock 已开启</small>
        </label>
        <div class="portal-auth__actions">
          <button class="portal-action portal-action--primary" id="unlock-button" type="submit">解锁编辑器</button>
        </div>
        <p class="portal-privacy-line">密码与解密后的凭证均不会保存到浏览器存储。关闭页面即退出。</p>
      </form>

      <form class="portal-auth__form portal-setup-form" id="setup-form" autocomplete="off" hidden>
        <div class="portal-setup-steps" aria-label="Initial setup steps">
          <span><b>1</b> 创建专用 Token</span><span><b>2</b> 设置固定密码</span><span><b>3</b> 加密并保存</span>
        </div>

        <label class="portal-field portal-field--wide" for="setup-token">
          <span>一次性 GitHub Token <small>初始化后不再需要粘贴</small></span>
          <span class="portal-password-control">
            <input id="setup-token" type="password" placeholder="github_pat_…" autocomplete="off" autocapitalize="none" spellcheck="false" required />
            <button type="button" class="portal-password-toggle" data-password-toggle="setup-token" aria-label="显示 Token">显示</button>
          </span>
        </label>

        <div class="portal-setup-passwords">
          <label class="portal-field" for="setup-password">
            <span>设置管理密码 <small>至少 8 个字符</small></span>
            <span class="portal-password-control">
              <input id="setup-password" type="password" minlength="8" maxlength="128" autocomplete="new-password" required />
              <button type="button" class="portal-password-toggle" data-password-toggle="setup-password" aria-label="显示密码">显示</button>
            </span>
            <small class="portal-caps-hint" data-caps-hint hidden>Caps Lock 已开启</small>
          </label>
          <label class="portal-field" for="setup-password-confirm">
            <span>再次输入 <small>Confirm password</small></span>
            <span class="portal-password-control">
              <input id="setup-password-confirm" type="password" minlength="8" maxlength="128" autocomplete="new-password" required />
              <button type="button" class="portal-password-toggle" data-password-toggle="setup-password-confirm" aria-label="显示密码">显示</button>
            </span>
          </label>
        </div>

        <p class="portal-password-advice">至少 8 个字符；建议使用一条不与其他账号共用的密码。</p>

        <div class="portal-auth__actions">
          <button class="portal-action portal-action--primary" id="setup-button" type="submit">加密并启用编辑器</button>
          <a class="portal-action portal-action--line" href={tokenUrl} target="_blank" rel="noreferrer">创建专用 Token ↗</a>
        </div>

        <details class="portal-token-guide">
          <summary>Token 权限怎么选？</summary>
          <ol>
            <li>Resource owner 选择 <strong>sci-m-wang</strong>。</li>
            <li>Repository access 选择 <strong>Only select repositories</strong>，仅勾选 <strong>sci-m-wang.github.io</strong>。</li>
            <li>Repository permissions 中只将 <strong>Contents</strong> 设为 <strong>Read and write</strong>。</li>
            <li>生成后只需在这里使用一次。初始化完成后，仓库中只留下加密密文。</li>
          </ol>
        </details>
      </form>
    </section>

    <section class="portal-editor" id="editor-panel" aria-labelledby="editor-title" hidden>
      <header class="portal-account-bar">
        <div class="portal-account" id="portal-account">
          <span class="portal-account__avatar" aria-hidden="true">MW</span>
          <span><strong id="account-name">sci-m-wang</strong><small>Encrypted vault unlocked · Session only</small></span>
        </div>
        <div class="portal-account-bar__actions">
          <span class="portal-dirty-status" id="dirty-status" data-dirty="false">所有修改已保存</span>
          <a href="https://github.com/sci-m-wang/sci-m-wang.github.io/commits/master" target="_blank" rel="noreferrer">提交记录 ↗</a>
          <button id="change-password-button" type="button">修改密码</button>
          <button id="logout-button" type="button">锁定编辑器</button>
        </div>
      </header>

      <div class="portal-publish-progress" id="publish-progress" aria-live="polite" hidden>
        <div><strong id="publish-title">正在发布</strong><span id="publish-copy">GitHub 已收到修改。</span></div>
        <ol>
          <li data-publish-step="commit"><span>1</span>已保存</li>
          <li data-publish-step="build"><span>2</span>正在构建</li>
          <li data-publish-step="live"><span>3</span>主页上线</li>
        </ol>
        <a id="publish-link" href="#" target="_blank" rel="noreferrer" hidden>查看 GitHub ↗</a>
      </div>

      <div class="portal-editor__heading">
        <div>
          <p class="section-heading__index">02 · Edit & publish / 编辑并发布</p>
          <h2 id="editor-title">Content archive</h2>
        </div>
        <p>Every save creates one traceable Git commit and automatically rebuilds the homepage.<br />每次保存都会生成一条可追踪的 Git 提交，并自动更新主页。</p>
      </div>

      <nav class="portal-tabs" aria-label="Content type">
        <button class="portal-tab is-active" type="button" data-section="publications"><span>01</span>论文 Publications</button>
        <button class="portal-tab" type="button" data-section="experience"><span>02</span>经历 Experience</button>
        <button class="portal-tab" type="button" data-section="funding"><span>03</span>Funding</button>
        <button class="portal-tab" type="button" data-section="projects"><span>04</span>项目 Projects</button>
        <button class="portal-tab" type="button" data-section="awards"><span>05</span>奖项 Awards</button>
        <button class="portal-tab" type="button" data-section="activities"><span>06</span>报告与服务</button>
        <button class="portal-tab" type="button" data-section="news"><span>07</span>动态与报道</button>
        <button class="portal-tab" type="button" data-section="profile"><span>08</span>主页信息</button>
        <button class="portal-tab" type="button" data-section="pages"><span>09</span>子页面 Pages</button>
        <button class="portal-tab" type="button" data-section="pageEntries"><span>10</span>页面条目</button>
      </nav>

      <div class="portal-workspace">
        <aside class="portal-library" aria-label="Existing entries">
          <div class="portal-library__toolbar">
            <label for="entry-search">搜索条目</label>
            <input id="entry-search" type="search" placeholder="输入标题或年份" />
          </div>
          <button class="portal-new-button" id="new-entry-button" type="button">＋ 新增论文</button>
          <div class="portal-entry-list" id="entry-list" role="list"></div>
        </aside>

        <section class="portal-form-surface" aria-label="Entry editor">
          <div class="portal-empty-state" id="empty-state">
            <span>←</span>
            <h3>Choose an entry to edit.</h3>
            <p>从左侧选择已有条目，或点击“新增”开始录入。</p>
          </div>

          <form class="portal-content-form" id="content-form" novalidate hidden>
            <header class="portal-content-form__header">
              <div>
                <p class="section-heading__index" id="form-mode">Editing existing entry</p>
                <h3 id="form-title">Publication</h3>
              </div>
              <button class="portal-text-button" id="cancel-edit-button" type="button">取消</button>
            </header>

            <div class="portal-fields" id="form-fields"></div>

            <label class="portal-field portal-field--wide" for="commit-message">
              <span>提交说明 <small>Commit message</small></span>
              <input id="commit-message" type="text" maxlength="120" required />
            </label>

            <aside class="portal-save-note">
              <strong>Save path / 保存路径</strong>
              <span id="save-path">src/data/publications.json → master</span>
              <p>保存前会再次检查远端版本；如有更新冲突，本页不会覆盖新数据。</p>
            </aside>

            <footer class="portal-content-form__footer">
              <p id="form-feedback" aria-live="polite">检查必填项后即可发布。</p>
              <button class="portal-action portal-action--primary" id="save-button" type="submit">检查并发布</button>
            </footer>
          </form>
        </section>
      </div>
    </section>

    <dialog class="portal-confirm-dialog" id="save-dialog" aria-labelledby="save-dialog-title">
      <form method="dialog">
        <p class="section-heading__index">Final check / 发布确认</p>
        <h2 id="save-dialog-title">Publish these changes?</h2>
        <p id="save-dialog-summary">请确认本次修改。</p>
        <dl id="save-dialog-changes"></dl>
        <div class="portal-confirm-dialog__actions">
          <button class="portal-action portal-action--line" value="cancel">返回检查</button>
          <button class="portal-action portal-action--primary" value="confirm">确认保存并发布</button>
        </div>
      </form>
    </dialog>

    <dialog class="portal-confirm-dialog portal-password-dialog" id="password-dialog" aria-labelledby="password-dialog-title">
      <form id="password-form">
        <p class="section-heading__index">Vault settings / 保险箱设置</p>
        <h2 id="password-dialog-title">Change homepage password</h2>
        <p>新密码会重新加密现有凭证，并生成一条可追踪的 Git 提交。</p>
        <label class="portal-field portal-field--wide" for="current-password">
          <span>当前密码</span>
          <input id="current-password" type="password" autocomplete="current-password" required />
        </label>
        <label class="portal-field portal-field--wide" for="new-password">
          <span>新密码 <small>至少 8 个字符</small></span>
          <input id="new-password" type="password" minlength="8" maxlength="128" autocomplete="new-password" required />
        </label>
        <label class="portal-field portal-field--wide" for="new-password-confirm">
          <span>再次输入新密码</span>
          <input id="new-password-confirm" type="password" minlength="8" maxlength="128" autocomplete="new-password" required />
        </label>
        <p class="portal-dialog-feedback" id="password-feedback" aria-live="polite"></p>
        <div class="portal-confirm-dialog__actions">
          <button class="portal-action portal-action--line" id="password-cancel-button" type="button">取消</button>
          <button class="portal-action portal-action--primary" id="password-save-button" type="submit">重新加密并保存</button>
        </div>
      </form>
    </dialog>

    <section class="portal-footnote">
      <p class="section-heading__index">Practical notes / 使用说明</p>
      <div>
        <p>This lightweight vault is intended for personal-site maintenance. Git history remains the recovery path for accidental edits. If the password is forgotten, revoke the old token, delete <code>public/admin-vault.json</code> on GitHub, and refresh this page to initialize again.</p>
        <p>这个轻量保险箱主要用于个人主页维护；误修改可随时通过 Git 历史恢复。如果忘记密码，撤销旧 Token、在 GitHub 删除 <code>public/admin-vault.json</code>，刷新本页即可重新初始化。</p>
      </div>
    </section>
  </main>

  <script src="../scripts/update-portal.js"></script>
</BaseLayout>

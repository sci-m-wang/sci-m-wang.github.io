---
import ExpandableRecord from "./ExpandableRecord.astro";
import LocalText from "./LocalText.astro";

interface Publication {
  id: string;
  title: string;
  authors: string;
  venue: string;
  venueShort: string;
  year: number;
  category: string;
  status: string;
  selected: boolean;
  badges: string[];
  abstract?: string | { en?: string; zh?: string };
  links: { paper: string; pdf: string; code: string };
  citations: { count: number; source: string; updatedAt: string };
}

export interface Props {
  publication: Publication;
  index: number;
}

const { publication: pub, index } = Astro.props as Props;
const authorParts = pub.authors.split("Ming Wang");
const abstract = typeof pub.abstract === "string"
  ? { en: pub.abstract, zh: pub.abstract }
  : { en: pub.abstract?.en || "", zh: pub.abstract?.zh || pub.abstract?.en || "" };
---

<article class="publication-record" data-publication data-category={pub.category} data-status={pub.status}>
  <ExpandableRecord
    index={index}
    title={pub.title}
    eyebrow={`${pub.venueShort} · ${pub.year}${pub.badges[0] ? ` · ${pub.badges[0]}` : ""}`}
    meta={pub.venue}
    citation={pub.citations.count}
    label="publication"
  >
    <div class="publication-detail">
      <div>
        <p class="publication-detail__authors">
          {authorParts.map((part, partIndex) => (
            <>{part}{partIndex < authorParts.length - 1 && <strong>Ming Wang</strong>}</>
          ))}
        </p>
        <p class="publication-detail__venue">{pub.venue} · {pub.year}</p>
        {abstract.en && <LocalText en={abstract.en} zh={abstract.zh} as="p" class="publication-detail__abstract" />}
      </div>
      <div class="publication-detail__links">
        {pub.links.paper && <a href={pub.links.paper} target="_blank" rel="noreferrer">Paper ↗</a>}
        {pub.links.pdf && <a href={pub.links.pdf} target="_blank" rel="noreferrer">PDF ↓</a>}
        {pub.links.code && <a href={pub.links.code} target="_blank" rel="noreferrer">Code ↗</a>}
        <a href="https://scholar.google.com/citations?user=dcqk_mMAAAAJ" target="_blank" rel="noreferrer">Google Scholar ↗</a>
      </div>
    </div>
  </ExpandableRecord>
</article>
